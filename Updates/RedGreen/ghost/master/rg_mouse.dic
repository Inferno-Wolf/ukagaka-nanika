//overlap the boys


//reference5 is the mouse button being clicked, in this case a left click
//reference3 is which character is being clicked
//reference4 will be the name of the hitbox the mouse is over
OnMouseDoubleClick
{
	if reference5 == 0
	{
		if reference3 == 1 {OnKeroMenu}
		//elseif reference3 == 2 {OnP2Menu}
		else {OnSakuraMenu}
	}
}

